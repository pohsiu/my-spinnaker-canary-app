{
  "name": "my-web-service-kayenta-config",
  "applications": ["my-web-service"],
  "metrics": [
    {
      "name": "HTTP 5xx Error Rate",
      "scopeName": "default",
      "groups": ["Web-IO"],
      "query": {
        "type": "prometheus",
        "metricName": "http_requests_total",
        "customInlineTemplate": "PromQL:sum(rate(http_requests_total{code=~\"5..\", app=\"my-web-service\", track=\"${scope}\"}[2m])) or vector(0)"
      },
      "analysisConfigurations": {
        "canary": {
          "direction": "increase"
        }
      },
      "critical": true
    },
    {
      "name": "HTTP p95 Latency",
      "scopeName": "default",
      "groups": ["Web-IO"],
      "query": {
        "type": "prometheus",
        "metricName": "http_request_duration_seconds",
        "customInlineTemplate": "PromQL:histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{app=\"my-web-service\", track=\"${scope}\"}[5m])) by (le))"
      },
      "analysisConfigurations": {
        "canary": {
          "direction": "increase"
        }
      }
    }
  ],
  "classifier": {
    "groupWeights": {
      "Web-IO": 100
    }
  }
}
