{
  "name": "my-web-service-kayenta-config",
  "applications": ["my-web-service"],
  "metrics": [
    {
      "name": "HTTP 5xx Error Rate",
      "scopeName": "default",
      "groups": ["Web-IO"],
      "query": {
        "type": "prometheus",
        "customFilter": "app=\"my-web-service\" AND track=\"${scope}\"",
        "metricName": "rate(http_requests_total{code=~\"5..\"}[2m])"
      },
      "analysisConfigurations": {
        "canary": {
          "direction": "increase"
        }
      },
      "critical": true
    },
    {
      "name": "HTTP p95 Latency",
      "scopeName": "default",
      "groups": ["Web-IO"],
      "query": {
        "type": "prometheus",
        "customFilter": "app=\"my-web-service\" AND track=\"${scope}\"",
        "metricName": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))"
      },
      "analysisConfigurations": {
        "canary": {
          "direction": "increase"
        }
      }
    }
  ],
  "classifier": {
    "groupWeights": {
      "Web-IO": 100
    }
  }
}
